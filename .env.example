# Base URL the server uses to call its own internal API routes
# (src/app/api/*) via absolute fetch() URLs — required in Server
# Components/Actions since relative URLs don't resolve there.
#
# Local dev: http://localhost:3000
# Production (e.g. Vercel): your deployed URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
